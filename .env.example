# Copy to .env and fill in secrets. Use a venv for local Python: see README.md
#   python -m venv .venv  →  activate  →  make install-deps

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
API_SERVICE_NAME=api
CORS_ORIGINS=http://localhost:3000

# Optional: override DATABASE_URL for pytest only (same schema as main DB)
# TEST_DATABASE_URL=postgresql+asyncpg://ci_user:changeme@127.0.0.1:5432/creative_intelligence_test

# --- Database (async SQLAlchemy / asyncpg) ---
DATABASE_URL=postgresql+asyncpg://ci_user:changeme@localhost:5432/creative_intelligence
DATABASE_READ_REPLICA_URL=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_EVENTS_STREAM=creativeiq:events

# --- Object storage (MinIO local / GCS production) ---
# GCP project for ADC / signed URLs when not using MinIO (CreativeIQ GCP project).
GCS_PROJECT_ID=creativeiq-493423
STORAGE_BUCKET_RAW_ADS=ci-dev-raw-ads
STORAGE_BUCKET_EXTRACTED=ci-dev-extracted
STORAGE_BUCKET_MODELS=ci-dev-models
STORAGE_BUCKET_BRAND_ASSETS=ci-dev-brand-assets
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# --- Gemini (Phase 2+ for decomposition; settings required in Phase 1) ---
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CACHE_ENABLED=true
# Optional: unit economics for Phase 7 generation metrics (USD per 1M tokens)
GEMINI_INPUT_USD_PER_1M_TOKENS=0
GEMINI_OUTPUT_USD_PER_1M_TOKENS=0

# --- Decomposition worker (Phase 2) ---
TRANSCRIPTION_METHOD=gemini
DECOMPOSITION_METRICS_PORT=9100
PROFILE_ENGINE_METRICS_PORT=9101

# --- Snowflake (Phase 3+; optional for local Phase 1) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=creative_intelligence
SNOWFLAKE_SCHEMA_RAW=raw
SNOWFLAKE_WAREHOUSE=ci_transform_wh
SNOWFLAKE_ROLE=

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
ADMIN_EMAILS=
CHAT_HISTORY_WINDOW=20
CHAT_TOOL_CALL_LIMIT=5
CHAT_RESPONSE_TARGET_WORDS_MIN=200
CHAT_RESPONSE_TARGET_WORDS_MAX=400
CHAT_CONTEXT_TIMEOUT_MS=500

# --- Docker Compose (postgres service) ---
POSTGRES_PASSWORD=changeme
